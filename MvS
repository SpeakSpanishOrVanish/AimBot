-- Instant-Shot Aimbot for Duels: Murderers vs Sheriffs
-- Enhanced button with bouncy press animation and instant fire

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

-- ===== Settings =====
local cooldownTime = 2.5
local lastShotTime = 0
local canShoot = true

-- Colors
local readyColor = Color3.fromRGB(0, 255, 0)
local cooldownColor = Color3.fromRGB(255, 0, 0)

-- ===== GUI =====
local screenGui = nil
local button = nil
local stroke = nil

-- Cache
local camera = Workspace.CurrentCamera
local localBeam = ReplicatedStorage:FindFirstChild("BindableEvents"):FindFirstChild("LocalBeam")
local killedRemote = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Killed")

-- Tween Configs
local colorTweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local pressTweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local releaseTweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)

-- ===== Team Check =====
local function isValidTarget(otherPlayer)
    if not otherPlayer or otherPlayer == player then return false end
    if not otherPlayer.Character then return false end
    local hum = otherPlayer.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    local myGame = player:GetAttribute("Game")
    local theirGame = otherPlayer:GetAttribute("Game")
    if myGame and theirGame and myGame ~= theirGame then return false end

    local myTeam = player:GetAttribute("Team")
    local theirTeam = otherPlayer:GetAttribute("Team")
    if myTeam and theirTeam and myTeam == theirTeam then return false end

    return true
end

-- ===== Weapon & Combat =====
local function getWeapon()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("fire") then
            return tool
        end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                tool.Parent = char
                return tool
            end
        end
    end
    return nil
end

local function hasClearLineOfSight(targetPlayer)
    local char = player.Character
    local tChar = targetPlayer.Character
    if not char or not tChar then return false end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local tRoot = tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChild("Torso")
    if not myRoot or not tRoot then return false end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {char, tChar}
    params.IgnoreWater = true
    
    local result = workspace:Raycast(myRoot.Position, tRoot.Position - myRoot.Position, params)
    return result == nil
end

local function getNearestVisibleEnemy()
    local char = player.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not myRoot then return nil end

    local nearest, minDist = nil, math.huge
    for _, other in pairs(Players:GetPlayers()) do
        if isValidTarget(other) then
            local oRoot = other.Character:FindFirstChild("HumanoidRootPart") or other.Character:FindFirstChild("Torso")
            if oRoot then
                local dist = (myRoot.Position - oRoot.Position).Magnitude
                if dist < minDist and hasClearLineOfSight(other) then
                    minDist = dist
                    nearest = other
                end
            end
        end
    end
    return nearest
end

local function shootEnemy(targetPlayer)
    local char = player.Character
    if not char then return false end
    local weapon = getWeapon()
    if not weapon then return false end
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or targetPlayer.Character:FindFirstChild("Torso")
    if not tRoot then return false end

    local startPos = handle.Position
    local hitPos = tRoot.Position

    if localBeam then pcall(function() localBeam:Fire(handle, hitPos) end) end
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote then pcall(function() fireRemote:FireServer() end) end
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote then pcall(function() beamRemote:FireServer(hitPos, startPos, handle) end) end
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote then
        local dir = (hitPos - startPos).Unit
        pcall(function() killRemote:FireServer(targetPlayer, dir) end)
    end
    if killedRemote then pcall(function() killedRemote:FireServer(targetPlayer) end) end

    return true
end

-- ===== GUI & Animation =====
local function createGUI()
    if screenGui then screenGui:Destroy() end

    local playerGui = player:WaitForChild("PlayerGui")
    screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AimbotButtonGui"
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true
    screenGui.Parent = playerGui

    local buttonContainer = Instance.new("Frame")
    buttonContainer.Size = UDim2.new(0, 70, 0, 70)
    buttonContainer.Position = UDim2.new(1, -58, 1, -218)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.Parent = screenGui

    button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundColor3 = readyColor
    button.BackgroundTransparency = 0.3
    button.Text = "FIRE"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.GothamBold
    button.TextSize = 18
    button.AutoButtonColor = false
    button.ZIndex = 10
    button.Parent = buttonContainer

    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 14)
    stroke = Instance.new("UIStroke", button)
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Thickness = 2.5

    local function animatePressEffect()
        -- Squish down
        TweenService:Create(button, pressTweenInfo, {
            Size = UDim2.new(0.85, 0, 0.85, 0),
            BackgroundTransparency = 0.1
        }):Play()
        
        task.wait(0.08)
        
        -- Bounce back
        TweenService:Create(button, releaseTweenInfo, {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 0.3
        }):Play()
    end

    local function setButtonState(isReady)
        local targetColor = isReady and readyColor or cooldownColor
        TweenService:Create(button, colorTweenInfo, {BackgroundColor3 = targetColor}):Play()
        button.Text = isReady and "FIRE" or "WAIT"
    end

    local function instantShoot()
        if not canShoot then return end
        
        local weapon = getWeapon()
        if not weapon then return end

        local target = getNearestVisibleEnemy()
        if target then
            if shootEnemy(target) then
                task.spawn(animatePressEffect)
                canShoot = false
                setButtonState(false)
                
                task.delay(cooldownTime, function()
                    canShoot = true
                    setButtonState(true)
                end)
            end
        else
            -- Feedback for no target found
            task.spawn(animatePressEffect)
        end
    end

    button.MouseButton1Down:Connect(instantShoot)
    button.TouchStarted:Connect(instantShoot)
    
    setButtonState(true)
end

-- ===== Init =====
player.CharacterAdded:Connect(function()
    task.wait(0.5)
    createGUI()
end)

if player.Character then createGUI() end

print("Smooth Instant Aimbot Loaded")
